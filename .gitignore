# Claude Code local settings
.claude/
# Lokální negitované poznámky pro Claude (soukromá/účtová/provozní fakta)
CLAUDE.local.md

# Internal dev/work files
games/party-survivors/claude_code_prompt.txt
games/party-survivors/plan.txt
games/party-survivors/postup.txt
games/party-survivors/logika.xlsx
~$*.xlsx
# Uživatelova interní složka s pracovními materiály — jen lokálně, ne na GitHub
games/party-survivors/.gitignore/

# Party Survivors — hudební mastery zůstávají jen lokálně; do hry/deploye jdou
# jen komprimované MP3 v music/compressed/ (generuje tools/build-music.js).
games/party-survivors/music/*
!games/party-survivors/music/compressed/

# Hudba na pozadí webu byla zrušena; případné zbylé lokální mastery v hudba/ do gitu nepatří.
hudba/
